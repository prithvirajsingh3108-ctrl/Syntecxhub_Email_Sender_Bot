# .env.example
# Copy this file to .env and fill in your real credentials.
# NEVER commit the .env file to version control.

# Your Gmail address
EMAIL_ADDRESS=your_email@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to generate: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# SMTP server settings (Gmail defaults — change only if using another provider)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
